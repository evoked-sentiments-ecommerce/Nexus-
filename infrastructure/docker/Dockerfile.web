# syntax=docker/dockerfile:1
FROM node:20-alpine AS builder
WORKDIR /app
COPY apps/nexus-web/package*.json ./
RUN npm ci
COPY apps/nexus-web/ ./
# Build if a build script exists, otherwise skip
RUN if [ -f "tsconfig.json" ] && grep -q '"build"' package.json; then npm run build 2>/dev/null || true; fi

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup -S nexus && adduser -S nexus -G nexus
COPY --from=builder /app ./
RUN chown -R nexus:nexus /app
USER nexus
EXPOSE 3001
CMD ["node", "dist/index.js"]
